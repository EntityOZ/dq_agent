# =========================================================
# Meridian Platform — Environment Configuration Reference
# Copy to .env and fill in your values.
# =========================================================

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
MERIDIAN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000

# ── Licence ───────────────────────────────────────────────────────────────────
# Mode: 'online' (default) phones home to the licence server every 6 hours.
# Mode: 'offline' uses a pre-signed JWT token — for air-gapped deployments.
MERIDIAN_LICENCE_MODE=online
MERIDIAN_LICENCE_KEY=                        # issued by Meridian HQ (online mode)
MERIDIAN_LICENCE_TOKEN=                      # signed JWT from Meridian HQ (offline mode only)
MERIDIAN_LICENCE_SERVER_URL=https://licence.meridian.vantax.co.za/api/licence/validate
# Public key for offline token verification (baked into production image):
MERIDIAN_OFFLINE_PUBLIC_KEY=

# ── LLM — choose one tier ─────────────────────────────────────────────────────
# Tier 1 — Cloud API (Anthropic or Azure OpenAI):
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6          # optional override
#
# Tier 1 (Azure alternative):
# LLM_PROVIDER=azure_openai
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview
#
# Tier 2 — Bundled Ollama (local container):
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://llm:11434
OLLAMA_MODEL=qwen3.5:9b-instruct
#
# Tier 2 — Ollama Cloud (dev/CI):
# LLM_PROVIDER=ollama_cloud
# OLLAMA_BASE_URL=https://ollama.com/api/v1
# OLLAMA_API_KEY=
#
# Tier 3 — BYOLLM (any OpenAI-compatible endpoint):
# LLM_PROVIDER=custom
# CUSTOM_LLM_BASE_URL=https://your-llm.internal:8080/v1
# CUSTOM_LLM_API_KEY=
# CUSTOM_LLM_MODEL=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://meridian:${DB_PASSWORD}@db:5432/meridian
DATABASE_URL_SYNC=postgresql://meridian:${DB_PASSWORD}@db:5432/meridian
DB_PASSWORD=password                         # change this in production

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO (S3-compatible object storage) ─────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=meridian
MINIO_PASSWORD=minioadmin                    # change this in production
MINIO_BUCKET_UPLOADS=meridian-uploads
MINIO_BUCKET_REPORTS=meridian-reports

# ── Auth ──────────────────────────────────────────────────────────────────────
# local = built-in auth (default for customer deployments)
# clerk = Clerk.dev (used on Meridian HQ portal only)
AUTH_MODE=local
NEXT_PUBLIC_AUTH_MODE=local
CLERK_SECRET_KEY=                            # only for AUTH_MODE=clerk

# ── Initial setup ─────────────────────────────────────────────────────────────
INITIAL_TENANT_NAME=                         # first tenant created by install.sh

# ── SAP RFC Sync ──────────────────────────────────────────────────────────────
SAP_CONNECTOR=rfc                            # rfc | ctypes | odata | mock
CREDENTIAL_MASTER_KEY=                       # AES-256 key for SAP credential encryption
SAP_RFC_USER=RFC_USER                        # SAP technical user for RFC connections

# ── Notifications ─────────────────────────────────────────────────────────────
RESEND_API_KEY=                              # or configure SMTP below for air-gapped
TEAMS_WEBHOOK_URL=                           # optional Teams webhook

# ── SMTP (air-gapped deployments — alternative to Resend) ────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@meridian.local

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=                                  # optional Sentry error tracking
