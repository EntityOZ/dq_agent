# CORS — comma-separated list of allowed frontend origins
# For production: set to your deployment domain, e.g. https://meridian.customer.com
MERIDIAN_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://frontend:3000

# LLM — choose one mode
LLM_PROVIDER=ollama                          # ollama | ollama_cloud | anthropic
OLLAMA_BASE_URL=http://llm:11434             # internal Docker service address
OLLAMA_MODEL=llama3.1:70b
OLLAMA_API_KEY=                              # only needed for ollama_cloud
ANTHROPIC_API_KEY=                           # only needed for anthropic

# Database
DATABASE_URL=postgresql://vantax:password@db:5432/vantax

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vantax
MINIO_SECRET_KEY=
MINIO_BUCKET_UPLOADS=vantax-uploads
MINIO_BUCKET_REPORTS=vantax-reports

# Licence
LICENCE_KEY=                                 # issued by Meridian HQ portal
LICENCE_SERVER_URL=https://licence.meridian.vantax.co.za
LICENCE_FILE=                                # path to offline licence JSON file (air-gapped deployments)

# Air-gap mode
LICENCE_MODE=online                          # online | offline
LICENCE_FILE_PATH=                           # path to offline licence file (offline mode only)
LICENCE_SECRET=                              # HMAC secret for offline licence validation

# Notifications
RESEND_API_KEY=                              # or configure SMTP_HOST for air-gapped
TEAMS_WEBHOOK_URL=                           # optional — per tenant config

# Auth
CLERK_SECRET_KEY=                            # or set AUTH_MODE=local for air-gapped
AUTH_MODE=local                              # local | clerk
NEXT_PUBLIC_AUTH_MODE=local                  # set to "local" to skip Clerk in dev

# Initial setup
INITIAL_TENANT_NAME=                         # name for the first tenant created by install.sh

# SMTP (air-gapped deployments — alternative to Resend)
SMTP_HOST=                                   # set for air-gapped SMTP relay
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@meridian.local

# SAP RFC Sync
CREDENTIAL_MASTER_KEY=                       # AES-256 master key for SAP credential encryption
SAP_RFC_USER=RFC_USER                        # SAP technical user for RFC connections

# Observability
SENTRY_DSN=                                  # optional

# Database password (used by docker-compose)
DB_PASSWORD=password

# MinIO password (used by docker-compose)
MINIO_PASSWORD=minioadmin
