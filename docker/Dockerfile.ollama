# =========================================================
# Meridian Ollama — Pre-baked model image (Tier 2)
# Build arg MODEL_NAME selects the bundled model
# =========================================================

FROM ollama/ollama:latest

ARG MODEL_NAME=qwen2.5:14b-q4_K_M
ENV MODEL_NAME=${MODEL_NAME}

# Pull the model at build time so customers don't need internet access
RUN ollama serve & \
    sleep 15 && \
    ollama pull ${MODEL_NAME} && \
    pkill ollama || true

EXPOSE 11434
CMD ["ollama", "serve"]
