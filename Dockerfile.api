FROM python:3.12-slim-bookworm

# Install system dependencies for WeasyPrint and curl (healthcheck)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    build-essential \
    libpango1.0-dev \
    libgdk-pixbuf-2.0-dev \
    libffi-dev \
    libcairo2-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Optional PyRFC install — keeps base image lightweight
ARG INSTALL_PYRFC=false
RUN if [ "$INSTALL_PYRFC" = "true" ]; then pip install pyrfc; fi

ENV PYTHONPATH=/app

EXPOSE 8000

CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]
